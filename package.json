    "tailwindcss": "^4.1.13",
    "typescript": "^5.3.0",
    "vite": "^7.0.0",
    "vue": "^3.5",
    "vue-router": "^4.2.0",
    "vue-tsc": "^3.0.8"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/video.js": "^7.3.58",
